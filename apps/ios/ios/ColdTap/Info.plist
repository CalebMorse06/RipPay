	<dict>
		<key>NSAllowsArbitraryLoads</key>
		<false/>
		<key>NSAllowsLocalNetworking</key>
		<true/>
	</dict>
	<key>NSBluetoothAlwaysUsageDescription</key>
	<string>ColdTap uses Bluetooth to connect to your Ledger hardware wallet for signing XRPL payments.</string>
