# -----------------------------------------------------------------------------
# ColdTap — apps/web environment
# -----------------------------------------------------------------------------
# Copy to .env.local for local development, or set these in your Vercel project.
# Every variable is optional; sensible defaults keep mock mode running.

# XRPL mode: "mock" (default) simulates the full lifecycle for reliable demos;
# "real" submits signed transactions to a live XRPL network.
XRPL_MODE=mock

# XRPL network. Ignored when XRPL_MODE=mock.
# Options: testnet | mainnet
XRPL_NETWORK=testnet

# Override the WebSocket endpoint if you want to point at a specific rippled.
# XRPL_WS_URL=wss://s.altnet.rippletest.net:51233

# Default Fee (in drops) suggested in /prepare responses. 12 gives headroom above
# the 10-drop reference cost. Override only if you know why.
# XRPL_DEFAULT_FEE_DROPS=12

# How many ledgers ahead of `current` to set LastLedgerSequence during autofill.
# XRPL_LEDGER_OFFSET=40

# Public base URL used when the request does not carry a Host header — e.g. when
# generating universal links from a cron job or server-only script. Vercel sets
# x-forwarded-host automatically, so this is usually unnecessary in production.
# PUBLIC_BASE_URL=https://coldtap.example.com

# Fallback base URL exposed to the client bundle for QR generation before the
# page has hydrated. Prefer PUBLIC_BASE_URL when possible.
# NEXT_PUBLIC_BASE_URL=https://coldtap.example.com
